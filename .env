<td>
    <span class="status 
    <%= 
        order.product.status === 'Pending' ? 'pending' : 
        order.product.status  === 'Shipped' ? 'shipped' : 
        order.product.status  === 'Delivered' ? 'delivered' : 
        order.product.status  === 'Cancelled' ? 'cancelled' : ''
    %>">
    <%= order.product.status.charAt(0).toUpperCase() + order.product.status.slice(1) %>
</span>     
</td>